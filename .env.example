# Copy to `.env` for local dev (`.env` is gitignored).
#
# Base URL of the CRM that receives ask/contact-form submissions
# (repo n_crmLeadRegister, endpoint POST /api/public/queries). When unset, the
# ask form disables sending and shows a local-dev note. The deployed GitHub Pages
# build gets this from the workflow (.github/workflows/deploy.yml).
#
# Point it at a CRM you can actually reach, no trailing slash. Examples:
#   NUXT_PUBLIC_CRM_URL=https://digihire.ai/crm     # shared/prod CRM
#   NUXT_PUBLIC_CRM_URL=https://zettamine.qa/crm    # local SANS stack via Caddy
#   NUXT_PUBLIC_CRM_URL=http://localhost:3010       # CRM dev server, if run directly
#
# For a submit to succeed the CRM must (a) be running with the code in this repo
# (which allowlists http://localhost:3000 and https://xteamjack.github.io) and
# (b) be reachable from the browser.
#
# NOTE: resolving this from the config server's `apps.crm` entry (the SANS way)
# is a deferred architecture change; for now it stays a build-time env var.
NUXT_PUBLIC_CRM_URL=
